NODE_ENV=production
APP_NAME=Nexus Connections
APP_SHORT_NAME=NC
APP_CREATOR=lukscode
APP_GITHUB=https://github.com/lukscode-py
APP_CHANNEL=@vixzap
APP_PORT=3333
APP_BASE_URL=https://your-domain.com

NC_DATA_DIR=./var/data
NC_TMP_DIR=/tmp/nexus-connections

NC_SESSION_PREFIX=session-nexusnx
NC_QR_EXPIRES_SECONDS=60
NC_PAIR_EXPIRES_SECONDS=60
NC_DOWNLOAD_EXPIRES_SECONDS=300
NC_CLEANUP_INTERVAL_SECONDS=60

NC_MAX_ACTIVE_PER_IP=1
NC_MAX_GLOBAL_ACTIVE=3

NC_RATE_ERROR_LIMIT=5
NC_RATE_ERROR_WINDOW_SECONDS=360
NC_RATE_ERROR_BLOCK_SECONDS=900

NC_RATE_FAST_LIMIT=5
NC_RATE_FAST_WINDOW_SECONDS=30
NC_RATE_FAST_BLOCK_SECONDS=1800

NC_RATE_PHONE_LIMIT=3
NC_RATE_PHONE_WINDOW_SECONDS=600
NC_RATE_PHONE_BLOCK_SECONDS=1800

NC_JSON_LIMIT=32kb
NC_TRUST_PROXY=true
