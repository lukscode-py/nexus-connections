MODE_EXPORT=full
NC_AUTO_JOIN_LINKS=https://whatsapp.com/channel/0029Vb8IaIP4tRrqGHe3Xn2C
NC_AUTO_JOIN_DELAY_MS=1200

NODE_ENV=production
APP_NAME=Nexus Connections
APP_SHORT_NAME=NC
APP_CREATOR=lukscode
APP_GITHUB=https://github.com/lukscode-py
APP_CHANNEL=@vixzap
APP_PORT=3333
APP_BASE_URL=https://your-domain.com

NC_DATA_DIR=./var/data
NC_TMP_DIR=./var/tmp

NC_SESSION_PREFIX=session-nexusnx
NC_QR_EXPIRES_SECONDS=60
NC_PAIR_EXPIRES_SECONDS=60
NC_DOWNLOAD_EXPIRES_SECONDS=60
NC_CLEANUP_INTERVAL_SECONDS=30

NC_MAX_ACTIVE_PER_IP=4
NC_MAX_GLOBAL_ACTIVE=20

NC_QUEUE_ENABLED=true
NC_QUEUE_MAX_GLOBAL=30
NC_QUEUE_MAX_PER_IP=4
NC_QUEUE_EXPIRES_SECONDS=60
NC_QUEUE_POLL_SECONDS=2

NC_SYNC_WAIT_MS=10000
NC_AFTER_JOIN_SYNC_WAIT_MS=5000
NC_CLOSE_WAIT_MS=1200

NC_CREDS_READY_TIMEOUT_MS=30000
NC_CREDS_READY_INTERVAL_MS=500
NC_CREDS_MIN_PREKEY_ID=31
NC_CREDS_REQUIRE_ROUTING_INFO=true
NC_CREDS_REQUIRE_ACCOUNT_SYNC=true

NC_RATE_ERROR_LIMIT=5
NC_RATE_ERROR_WINDOW_SECONDS=360
NC_RATE_ERROR_BLOCK_SECONDS=900

NC_RATE_FAST_LIMIT=5
NC_RATE_FAST_WINDOW_SECONDS=30
NC_RATE_FAST_BLOCK_SECONDS=1800

NC_RATE_PHONE_LIMIT=3
NC_RATE_PHONE_WINDOW_SECONDS=600
NC_RATE_PHONE_BLOCK_SECONDS=1800

NC_JSON_LIMIT=32kb
NC_TRUST_PROXY=true
